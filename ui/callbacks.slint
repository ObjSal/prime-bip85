// Globals shared between Rust and the UI. Screen map:
// 0 = derive form, 1 = result, 2 = saved-files browser, 3 = saved-file viewer.

export global Ui {
    in-out property <int> screen: 0;
    in-out property <bool> busy: false;
    in-out property <string> error: "";
    // BIP-32 fingerprint of the device master seed's root ("" until known).
    in-out property <string> master-fp: "";
}

// Derive form state (indices are read by Rust on derive()).
export global Form {
    // 0 = 12 words, 1 = 18 words, 2 = 24 words, 3 = WIF, 4 = XPRV,
    // 5 = HEX 32, 6 = HEX 64, 7 = Password (21-char base64).
    in-out property <int> app-index: 0;
    in-out property <int> child-index: 0;
    // 0 = mainnet, 1 = testnet. Only meaningful (and only shown) for the
    // network-encoded outputs, WIF and XPRV.
    in-out property <int> network-index: 0;
    out property <bool> network-relevant: app-index == 3 || app-index == 4;
    // Password length, 20–86 (BIP-85 spec range; 21, the default, is
    // the spec's canonical example length).
    in-out property <int> pwd-len: 21;
    out property <bool> pwd-relevant: app-index == 7;
}

// Last derived secret, for the result screen.
export global Derived {
    in-out property <string> app-label;
    in-out property <bool> testnet: false;
    in-out property <string> path;
    // Child fingerprint; "" for WIF/HEX which aren't BIP-32 nodes.
    in-out property <string> fingerprint;
    in-out property <string> display;
    in-out property <bool> has-seedqr: false;
    in-out property <bool> show-qr: false;
    // False for passwords — they gate accounts, they don't hold coins.
    in-out property <bool> spendable: true;
    in-out property <image> qr;
}

export struct SavedFile {
    name: string,
    location: string, // "Internal" | "Airlock"
}

export global Saved {
    in-out property <[SavedFile]> files;
    in-out property <string> viewer-name;
    in-out property <string> viewer-location;
    in-out property <string> viewer-text;
}

export global Callbacks {
    callback derive();
    callback save(int);            // 0 = internal (User), 1 = Airlock
    callback refresh-saved();
    callback open-saved(string, string);   // name, location
    callback delete-saved();               // deletes the file open in the viewer
}
